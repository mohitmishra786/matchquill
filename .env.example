# Environment Variables Example
# Copy this to .env (and frontend/.env) and fill in your values.
# Keep secrets out of git. This file must stay in sync with backend/app/config.py
# and frontend env usage.

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/cv_wiz

# -----------------------------------------------------------------------------
# Redis Cache (required — REDIS_URL or Upstash REST pair)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_RES_KV_REST_API_URL=
# UPSTASH_REDIS_RES_KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# Groq LLM API
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# NextAuth / Auth
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars
# AUTH_SECRET can be used instead of / in addition to NEXTAUTH_SECRET (v5)
# AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
# FRONTEND_API_URL is where the Python backend fetches profile data
FRONTEND_API_URL=http://localhost:3000

# Backend API URL (for extension / public clients)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side backend URL used by Next.js API proxies (SSRF-protected)
BACKEND_URL=http://localhost:8000
# Optional comma-separated allowed hosts for BACKEND_URL
ALLOWED_BACKEND_HOSTS=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# Admin / security
# -----------------------------------------------------------------------------
# Comma-separated emails granted admin access (bootstrap for audit logs)
# Prefer setting User.role=ADMIN in the database for production.
ADMIN_EMAILS=

# Shared secret for service-to-service internal API calls (optional)
INTERNAL_API_SECRET=

# -----------------------------------------------------------------------------
# Feature flags (comma-separated). Empty = defaults for stable features.
# -----------------------------------------------------------------------------
FEATURE_FLAGS=
# NEXT_PUBLIC_FEATURE_FLAGS=

# -----------------------------------------------------------------------------
# Cache / PDF tuning (optional)
# -----------------------------------------------------------------------------
# CACHE_TTL=300
# CACHE_TTL_SHORT=60
# CACHE_TTL_LONG=3600
# MAX_RESUME_PAGES=1

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# APP_ENV=development

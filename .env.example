# Environment Variables Example
# Copy this to .env (and frontend/.env) and fill in your values.
# Keep secrets out of git. This file must stay in sync with backend/app/config.py
# and frontend env usage.

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/matchquill

# -----------------------------------------------------------------------------
# Redis Cache (required — REDIS_URL or Upstash REST pair)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_RES_KV_REST_API_URL=
# UPSTASH_REDIS_RES_KV_REST_API_TOKEN=

# -----------------------------------------------------------------------------
# Groq LLM API
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# NextAuth / Auth
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars
# AUTH_SECRET can be used instead of / in addition to NEXTAUTH_SECRET (v5)
# AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend / CORS / Vercel unified deploy
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
# Backend fetches profile data from the Next.js app (same origin on Vercel).
# Optional on Vercel — defaults to https://{VERCEL_URL} when unset.
FRONTEND_API_URL=http://localhost:3000

# Server-side Python API base used by Next.js proxies (SSRF-protected).
# Local: direct uvicorn. Vercel: optional — auto-resolves to https://{VERCEL_URL}/api/py
BACKEND_URL=http://localhost:8000/api/py
# Optional comma-separated allowed hosts for BACKEND_URL
ALLOWED_BACKEND_HOSTS=

# Public backend URL (Chrome extension / client-side). Must include /api/py on Vercel.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/py

# Upload size (bytes). Vercel Functions max body is 4.5 MB — default 4 MB on Vercel.
# MAX_UPLOAD_BYTES=4194304
# NEXT_PUBLIC_MAX_UPLOAD_BYTES=4194304

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# Admin / security
# -----------------------------------------------------------------------------
# Comma-separated emails granted admin access (bootstrap for audit logs)
# Prefer setting User.role=ADMIN in the database for production.
ADMIN_EMAILS=

# Shared secret for service-to-service internal API calls (optional)
INTERNAL_API_SECRET=

# -----------------------------------------------------------------------------
# Feature flags (comma-separated). Empty = defaults for stable features.
# -----------------------------------------------------------------------------
# semantic_matching: blend embedding-based (sentence-transformers) semantic
#   similarity into relevance scoring, in addition to the always-on keyword
#   score. Requires `pip install -r backend/requirements-semantic.txt`; if
#   that optional dependency isn't installed, this flag is a no-op and
#   scoring silently stays keyword-only.
FEATURE_FLAGS=
# NEXT_PUBLIC_FEATURE_FLAGS=

# -----------------------------------------------------------------------------
# Cache / PDF tuning (optional)
# -----------------------------------------------------------------------------
# CACHE_TTL=300
# CACHE_TTL_SHORT=60
# CACHE_TTL_LONG=3600
# MAX_RESUME_PAGES=1

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# APP_ENV=production

# -----------------------------------------------------------------------------
# Vercel deployment notes (set in Vercel dashboard — do not commit secrets)
# -----------------------------------------------------------------------------
# 1. Connect repo with Root Directory = repository root (NOT frontend/).
# 2. vercel.json uses Vercel Services: frontend/ + backend/ on one domain.
# 3. Run `cd frontend && npx prisma migrate deploy` against production DATABASE_URL.
# 4. WeasyPrint PDF generation may be unavailable on Vercel serverless (JSON still works).
#    For full PDF support, run backend via backend/Dockerfile on Render/Railway/Fly.